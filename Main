local UserInputService = game:GetService("UserInputService")
local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local UICorner = Instance.new("UICorner")
local TitleBar = Instance.new("Frame")
local CloseBtn = Instance.new("TextButton")
local Sidebar = Instance.new("Frame")
local MainContent = Instance.new("ScrollingFrame")
local UIListLayout = Instance.new("UIListLayout")

-- Cấu hình màu sắc chuẩn theo ảnh
local BG_DARK = Color3.fromRGB(20, 20, 20)
local BG_LIGHTER = Color3.fromRGB(30, 30, 30)
local ACCENT_GREEN = Color3.fromRGB(0, 200, 0)
local TOGGLE_KEY = Enum.KeyCode.RightControl -- Phím để đóng/mở nhanh (Chuột phải Ctrl)

-- 1. Khởi tạo ScreenGui
ScreenGui.Name = "CleanGui_Base"
ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
ScreenGui.ResetOnSpawn = false

-- 2. Khung chính (Main Frame)
MainFrame.Name = "MainFrame"
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = BG_DARK
MainFrame.Position = UDim2.new(0.5, -250, 0.5, -150)
MainFrame.Size = UDim2.new(0, 500, 0, 300)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
MainFrame.Draggable = true -- Có thể kéo di chuyển

UICorner.CornerRadius = UDim.new(0, 10)
UICorner.Parent = MainFrame

-- 3. Thanh tiêu đề & Nút X
TitleBar.Name = "TitleBar"
TitleBar.Parent = MainFrame
TitleBar.BackgroundColor3 = BG_LIGHTER
TitleBar.Size = UDim2.new(1, 0, 0, 35)
TitleBar.BorderSizePixel = 0

local TitleCorner = Instance.new("UICorner")
TitleCorner.CornerRadius = UDim.new(0, 10)
TitleCorner.Parent = TitleBar

CloseBtn.Name = "CloseBtn"
CloseBtn.Parent = TitleBar
CloseBtn.BackgroundTransparency = 1
CloseBtn.Position = UDim2.new(1, -35, 0, 0)
CloseBtn.Size = UDim2.new(0, 35, 0, 35)
CloseBtn.Font = Enum.Font.GothamBold
CloseBtn.Text = "X"
CloseBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
CloseBtn.TextSize = 14

-- 4. Sidebar (Thanh bên trái)
Sidebar.Name = "Sidebar"
Sidebar.Parent = MainFrame
Sidebar.BackgroundColor3 = BG_DARK
Sidebar.Position = UDim2.new(0, 0, 0, 35)
Sidebar.Size = UDim2.new(0, 100, 1, -35)
Sidebar.BorderSizePixel = 0

local SidebarBtn = Instance.new("Frame") -- Nút xanh giả trên Sidebar
SidebarBtn.Parent = Sidebar
SidebarBtn.BackgroundColor3 = ACCENT_GREEN
SidebarBtn.Position = UDim2.new(0, 10, 0, 10)
SidebarBtn.Size = UDim2.new(0, 80, 0, 30)
Instance.new("UICorner", SidebarBtn).CornerRadius = UDim.new(0, 8)

-- 5. Vùng nội dung (Main Content)
MainContent.Name = "MainContent"
MainContent.Parent = MainFrame
MainContent.BackgroundColor3 = BG_DARK
MainContent.Position = UDim2.new(0, 110, 0, 45)
MainContent.Size = UDim2.new(1, -120, 1, -55)
MainContent.BackgroundTransparency = 1
MainContent.ScrollBarThickness = 2
MainContent.CanvasSize = UDim2.new(0, 0, 2, 0)

UIListLayout.Parent = MainContent
UIListLayout.Padding = UDim.new(0, 8)

-- Hàm tạo các thanh ngang rỗng
local function AddBar(color)
    local bar = Instance.new("Frame")
    bar.Parent = MainContent
    bar.BackgroundColor3 = color
    bar.Size = UDim2.new(1, 0, 0, 35)
    bar.BorderSizePixel = 0
    Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 6)
end

AddBar(ACCENT_GREEN) -- Thanh trên cùng
for i = 1, 5 do AddBar(BG_LIGHTER) end -- Các thanh xám rỗng
AddBar(ACCENT_GREEN) -- Thanh dưới cùng

-- 6. Tính năng Đóng/Mở
CloseBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = false
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == TOGGLE_KEY then
        MainFrame.Visible = not MainFrame.Visible
    end
end)
