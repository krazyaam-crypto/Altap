local function CreateStatusLabel(text)
    local label = Instance.new("TextLabel", StatusPage)
    label.Size = UDim2.new(0.95, 0, 0, 28)
    label.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    label.Text = text
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.GothamMedium
    label.TextSize = 11
    Instance.new("UICorner", label).CornerRadius = UDim.new(0, 4)
    return label
end

local TimerLab = CreateStatusLabel("Timer: 0h 0m 0s")
local SvrTimerLab = CreateStatusLabel("Server Timer: 0h 0m 0s")
local EliteLab = CreateStatusLabel("Elite Hunter: ❌")
local DKLab = CreateStatusLabel("Dough King: ❌")
local KataLab = CreateStatusLabel("Katakuri: ❌")
local MobLab = CreateStatusLabel("Cake Prince: Checking Mobs...")
local TyrantLab = CreateStatusLabel("Tyrant Eyes: 0 Eyes")
local LeviLab = CreateStatusLabel("Leviathan: Checking...")

-- 5. LOGIC CẬP NHẬT TRẠNG THÁI
local function formatT(s)
    return string.format("%dh %dm %ds", s/3600, (s/60)%60, s%60)
end

spawn(function()
    while wait(1) do
        TimerLab.Text = "Timer: " .. formatT(os.time() - StartTime)
        SvrTimerLab.Text = "Server Timer: " .. formatT(math.floor(workspace.DistributedGameTime))
        
        -- Quét Boss
        local enemies = workspace:FindFirstChild("Enemies") or workspace
        local eFound = false
        for _, v in pairs(enemies:GetChildren()) do
            if table.find({"Deandre", "Diablo", "Urban"}, v.Name) then
                EliteLab.Text = "Elite: " .. v.Name .. " ✅"
                EliteLab.TextColor3 = Color3.new(0, 1, 0)
                eFound = true break
            end
        end
        if not eFound then EliteLab.Text = "Elite Hunter: ❌" EliteLab.TextColor3 = Color3.new(1, 0.3, 0.3) end
        
        local dk = enemies:FindFirstChild("Dough King")
        DKLab.Text = "Dough King: " .. (dk and "✅" or "❌")
        DKLab.TextColor3 = dk and Color3.new(0, 1, 0) or Color3.new(1, 0.3, 0.3)
        
        local kt = enemies:FindFirstChild("Cake Prince")
        KataLab.Text = "Katakuri: " .. (kt and "✅" or "❌")
        KataLab.TextColor3 = kt and Color3.new(0, 1, 0) or Color3.new(1, 0.3, 0.3)

        -- Cake Prince Mobs Left
        pcall(function()
            local count = ReplicatedStorage.Remotes.Validator.GetEnemyCount:InvokeServer()
            MobLab.Text = "Cake Prince: " .. (500 - count) .. " Mobs"
        end)
        
        -- Tyrant Eyes & Leviathan
        local tyrant = enemies:FindFirstChild("Tyrant Eyes")
        TyrantLab.Text = tyrant and "Tyrant Eyes: ✅" or "Tyrant Eyes: 0 Eyes"
        LeviLab.Text = "Leviathan: You can find leviathan now"
        LeviLab.TextColor3 = Color3.new(0.7, 0.7, 1)
    end
end)

