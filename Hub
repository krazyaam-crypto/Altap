local SidebarScroll = Instance.new("ScrollingFrame")
local TabContainer = Instance.new("Frame")

-- Màu sắc chuẩn
local ACCENT_GREEN = Color3.fromRGB(0, 200, 0) 
local BG_DARK = Color3.fromRGB(15, 15, 15)
