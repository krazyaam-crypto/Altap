Name.TextSize = 10

-- Mở mặc định
Pages["Status Sever"].Visible = true

-- Đóng UI
CloseBtn.MouseButton1Click:Connect(function() MainFrame.Visible = false end)
UserInputService.InputBegan:Connect(function(io, p)
    if not p and io.KeyCode == Enum.KeyCode.LeftControl then MainFrame.Visible = not MainFrame.Visible end
end)
