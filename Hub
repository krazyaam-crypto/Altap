SidebarScroll.BackgroundTransparency = 1
SidebarScroll.ScrollBarThickness = 2
SidebarScroll.CanvasSize = UDim2.new(0, 0, 0, 0)

local Layout = Instance.new("UIListLayout", SidebarScroll)
Layout.Padding = UDim.new(0, 6)
Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
Instance.new("UIPadding", SidebarScroll).PaddingTop = UDim.new(0, 8)

-- 4. Tạo Tab & Nút (Màu xanh lá cho tất cả)
TabContainer.Parent = MainFrame
TabContainer.Position = UDim2.new(0, 150, 0, 40)
TabContainer.Size = UDim2.new(1, -155, 1, -45)
TabContainer.BackgroundTransparency = 1

local Pages = {}
local function AddTab(name)
    local btn = Instance.new("TextButton", SidebarScroll)
    btn.Size = UDim2.new(1, -20, 0, 32)
    btn.BackgroundColor3 = ACCENT_GREEN
    btn.Text = name
    btn.Font = Enum.Font.GothamMedium
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextSize = 12
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    local pg = Instance.new("ScrollingFrame", TabContainer)
    pg.Size = UDim2.new(1, 0, 1, 0)
    pg.BackgroundTransparency = 1
    pg.Visible = false
    Pages[name] = pg

    btn.MouseButton1Click:Connect(function()
        for _, v in pairs(Pages) do v.Visible = false end
        pg.Visible = true
    end)
    SidebarScroll.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 20)
end

-- Thứ tự nút chuẩn theo yêu cầu của bạn
AddTab("Status Sever")
AddTab("Shop")
AddTab("Local Player")
AddTab("Setting Farm")
AddTab("Farm")
AddTab("Stack Farm")
AddTab("Farmming Other")

