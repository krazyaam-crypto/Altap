-- 5. LOGIC FIX (BOSS CHECK & TOGGLE UI)
local function formatT(s)
    return string.format("%dh %dm %ds", s/3600, (s/60)%60, s%60)
end

spawn(function()
    while task.wait(1) do
        TimerL.Text = "Timer: " .. formatT(os.time() - StartTime)
        SvrTimerL.Text = "Server Timer: " .. formatT(math.floor(workspace.DistributedGameTime))
        
        -- Fix Check Boss (Duyệt cả Enemies và Map)
        local eliteNames = {"Deandre", "Diablo", "Urban"}
        local foundElite = nil
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Model") and table.find(eliteNames, v.Name) then foundElite = v.Name break end
        end
        EliteL.Text = foundElite and ("Elite: " .. foundElite .. " ✅") or "Elite Hunter: ❌"
        EliteL.TextColor3 = foundElite and Color3.new(0, 1, 0) or Color3.new(1, 0.3, 0.3)

        local dk = workspace:FindFirstChild("Dough King", true)
        DKL.Text = "Dough King: " .. (dk and "✅" or "❌")
        DKL.TextColor3 = dk and Color3.new(0, 1, 0) or Color3.new(1, 0.3, 0.3)

        local kata = workspace:FindFirstChild("Cake Prince", true) or workspace:FindFirstChild("Katakuri", true)
        KataL.Text = "Katakuri: " .. (kata and "✅" or "❌")
        KataL.TextColor3 = kata and Color3.new(0, 1, 0) or Color3.new(1, 0.3, 0.3)

        -- Cake Prince Mobs Left
        pcall(function()
            local count = ReplicatedStorage.Remotes.Validator.GetEnemyCount:InvokeServer()
            MobL.Text = "Cake Prince: " .. (500 - count) .. " Mobs"
        end)
    end
end)

