spawn(function()
    while task.wait() do
        if _G.AutoFarm then
            pcall(function()
                local monster = workspace.Enemies:FindFirstChild(_G.SelectMonster)
                if monster and monster:FindFirstChild("Humanoid") and monster.Humanoid.Health > 0 then
                    -- Bay lơ lửng trên đầu quái để không bị đánh
                    player.Character.HumanoidRootPart.CFrame = monster.HumanoidRootPart.CFrame * CFrame.new(0, 10, 0) * CFrame.Angles(math.rad(-90), 0, 0)
                    
                    -- Fast Attack: Bỏ qua animation để đánh nhanh hơn
                    local args = { [1] = "Attack" }
                    ReplicatedStorage.Modules.Net:FindFirstChild("RE/MainEvent"):FireServer(unpack(args))
                    game:GetService("VirtualUser"):ClickButton1(Vector2.new(0,0))
                end
            end)
        end
    end
end)

